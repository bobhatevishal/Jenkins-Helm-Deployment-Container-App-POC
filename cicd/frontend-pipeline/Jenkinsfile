pipeline {
    agent any

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'qa', 'uat', 'prod'], description: 'Target deployment environment')
        string(name: 'IMAGE_TAG', defaultValue: '', description: 'Override the container image tag for deployment/rollback. Leave empty to use latest commit.')
    }

    environment {
        // Azure Authentication
        ARM_CLIENT_ID       = credentials('aks_sp_client_id')
        ARM_CLIENT_SECRET   = credentials('aks_sp_secret')
        ARM_TENANT_ID       = credentials('aks_sp_tenant_id')
        
        // Subscription IDs
        SUB_ID_DEV          = credentials('subscription_id_dev')
        SUB_ID_QA           = credentials('subscription_id_qa')
        SUB_ID_UAT          = credentials('subscription_id_uat')
        SUB_ID_PROD         = credentials('subscription_id_prod')
        
        PROJECT_NAME        = "helmdeploymentapp"
        PRODUCT_NAME        = "snaplink"
        
        // Component Configuration
        COMPONENT_DIR       = "frontend"
        COMPONENT_REPO      = "snaplink-web"
        HELM_COMPONENT      = "frontend"
        HELM_VALUES_FILE    = "kube/snaplink/values/frontend.yaml"
        
        // Tag Logic
        COMMIT_ID           = "${env.GIT_COMMIT ? env.GIT_COMMIT.take(8) : ''}"
        RESOLVED_TAG        = "${params.IMAGE_TAG ?: env.COMPONENT_DIR + '-' + env.COMMIT_ID}"

        // Isolate Azure CLI profile to this workspace to prevent interference from other pipelines
        AZURE_CONFIG_DIR    = "${WORKSPACE}/.azure"
    }

    stages {
        stage('Setup') {
            steps {
                script { setup() }
            }
        }

        stage('Build in DEV') {
            when { expression { params.ENVIRONMENT == 'dev' && params.IMAGE_TAG == '' } }
            steps {
                script { build() }
            }
        }

        stage('Push to DEV ACR') {
            when { expression { params.ENVIRONMENT == 'dev' && params.IMAGE_TAG == '' } }
            steps {
                script { push() }
            }
        }

        stage('Deploy to AKS in DEV') {
            when { expression { params.ENVIRONMENT == 'dev' } }
            steps {
                script { deployToAKS('dev') }
            }
        }

        stage('Pull and push image to QA') {
            when { expression { params.ENVIRONMENT == 'qa' } }
            steps {
                script { pullTagAndPush('dev', 'qa') }
            }
        }

        stage('Deploy to AKS in QA') {
            when { expression { params.ENVIRONMENT == 'qa' } }
            steps {
                script { deployToAKS('qa') }
            }
        }

        stage('Pull and push image to UAT') {
            when { expression { params.ENVIRONMENT == 'uat' } }
            steps {
                script { pullTagAndPush('qa', 'uat') }
            }
        }

        stage('Deploy to AKS in UAT') {
            when { expression { params.ENVIRONMENT == 'uat' } }
            steps {
                script { deployToAKS('uat') }
            }
        }

        stage('Approve Prod Deployment') {
            when { expression { params.ENVIRONMENT == 'prod' } }
            steps {
                input message: "Push image and deploy application to PROD?", ok: "Deploy"
            }
        }

        stage('Pull and push image to PROD') {
            when { expression { params.ENVIRONMENT == 'prod' } }
            steps {
                script { pullTagAndPush('uat', 'prod') }
            }
        }

        stage('Deploy to AKS in PROD') {
            when { expression { params.ENVIRONMENT == 'prod' } }
            steps {
                script { deployToAKS('prod') }
            }
        }
    }

    post {
        always {
            script { cleanup() }
        }
        success { 
            echo " ${params.ENVIRONMENT} Deployment successful! Image: ${env.RESOLVED_TAG}" 
        }
        failure { 
            echo " ${params.ENVIRONMENT} Pipeline failed. Please check the logs." 
        }
    }
}

// ========== Functions ==========

def setup() {
    echo "=========================================================="
    echo "INIT: Logging into Azure for ${params.ENVIRONMENT} environment"
    def envName = params.ENVIRONMENT.toUpperCase()
    env.SUB_ID = env."SUB_ID_${envName}"
    echo "Subscription ID: ${env.SUB_ID}"
    echo "=========================================================="
    sh """
        az login --service-principal -u '${env.ARM_CLIENT_ID}' -p '${env.ARM_CLIENT_SECRET}' -t '${env.ARM_TENANT_ID}'
        az account set --subscription '${env.SUB_ID}'
    """
}

def build() {
    env.ACR_NAME = "${env.PROJECT_NAME}devacr"
    echo "----------------------------------------------------------"
    echo "BUILD: Authenticating with ACR: ${env.ACR_NAME}"
    sh "az acr login --name ${env.ACR_NAME}"
    
    echo "BUILD: Building ${env.COMPONENT_REPO}:${env.RESOLVED_TAG}"
    sh "docker build -t ${env.ACR_NAME}.azurecr.io/${env.COMPONENT_REPO}:${env.RESOLVED_TAG} src/${env.COMPONENT_DIR}"
    echo "----------------------------------------------------------"
}

def push() {
    echo "----------------------------------------------------------"
    echo "PUSH: Pushing ${env.COMPONENT_REPO}:${env.RESOLVED_TAG}"
    sh "docker push ${env.ACR_NAME}.azurecr.io/${env.COMPONENT_REPO}:${env.RESOLVED_TAG}"
    echo "----------------------------------------------------------"
}

def pullTagAndPush(sourceEnv, targetEnv) {
    def sourceAcrName = "${env.PROJECT_NAME}${sourceEnv}acr"
    def targetAcrName = "${env.PROJECT_NAME}${targetEnv}acr"

    echo "----------------------------------------------------------"
    echo "PROMOTE: Promoting image from ${sourceEnv.toUpperCase()} to ${targetEnv.toUpperCase()} ACR"
    
    sh "az acr login --name ${sourceAcrName}"
    sh "docker pull ${sourceAcrName}.azurecr.io/${env.COMPONENT_REPO}:${env.RESOLVED_TAG}"
    
    sh "az acr login --name ${targetAcrName}"
    sh """
        docker tag ${sourceAcrName}.azurecr.io/${env.COMPONENT_REPO}:${env.RESOLVED_TAG} ${targetAcrName}.azurecr.io/${env.COMPONENT_REPO}:${env.RESOLVED_TAG}
        docker push ${targetAcrName}.azurecr.io/${env.COMPONENT_REPO}:${env.RESOLVED_TAG}
    """
}

def deployToAKS(envName) {
    def targetAcrName = "${env.PROJECT_NAME}${envName}acr"
    def clusterName = "helm-deployment-app-${envName}-aks"
    def resourceGroup = "helm-deployment-app-${envName}-rg"

    echo "----------------------------------------------------------"
    echo "DEPLOY: Targeting ${envName.toUpperCase()} AKS Cluster"
    echo "Cluster Name: ${clusterName}"
    echo "Using Registry: ${targetAcrName}.azurecr.io"
    echo "Deploying Image Tag: ${env.RESOLVED_TAG}"
    
    sh """
        az account set --subscription '${env."SUB_ID_${envName.toUpperCase()}"}' --output none
        az aks get-credentials --resource-group ${resourceGroup} --name ${clusterName} --overwrite-existing --output none
        if helm status ${env.HELM_COMPONENT} > /dev/null 2>&1; then
            HELM_UPGRADE_OPT="--reuse-values"
        else
            HELM_UPGRADE_OPT=""
        fi

        sed -i -e "s|<registry>|${targetAcrName}.azurecr.io|g" \\
           -e "s|<repo_name>|${COMPONENT_REPO}|g" \\
           -e "s|<image_tag>|${RESOLVED_TAG}|g" ${HELM_VALUES_FILE}

        helm upgrade --install ${env.HELM_COMPONENT} helm_charts \\
            --namespace ${PRODUCT_NAME}-${params.ENVIRONMENT} --create-namespace \\
            \$HELM_UPGRADE_OPT \\
            -f ${HELM_VALUES_FILE}
    """
}

def cleanup() {
    echo 'Pipeline execution complete. Cleaning up...'
    
    // Remove local Docker images to save space on Jenkins agent
    sh "docker rmi ${env.PROJECT_NAME}${params.ENVIRONMENT}acr.azurecr.io/${env.COMPONENT_REPO}:${env.RESOLVED_TAG} || true"

    sh "az logout || true"
    cleanWs()
}
