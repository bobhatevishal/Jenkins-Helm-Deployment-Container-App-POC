pipeline {
    agent any

    parameters {
        choice(name: 'REGION', choices: ['Canada Central'], description: 'Deployment region')
        choice(name: 'ENVIRONMENT', choices: ['dev', 'qa', 'uat', 'prod'], description: 'Deployment environment')
        choice(name: 'ACTION', choices: ['plan', 'apply', 'destroy'], description: 'Terraform action')
        booleanParam(name: 'AUTO_APPROVE', defaultValue: false, description: 'Auto approve apply/destroy actions')
    }

    environment {
        // Service Principal Credentials
        ARM_CLIENT_ID       = credentials('aks_sp_client_id')
        ARM_CLIENT_SECRET   = credentials('aks_sp_secret')
        ARM_TENANT_ID       = credentials('aks_sp_tenant_id')
        
        // Explicit subscription IDs for each environment
        SUB_ID_DEV          = credentials('subscription_id_dev')
        SUB_ID_QA           = credentials('subscription_id_qa')
        SUB_ID_UAT          = credentials('subscription_id_uat')
        SUB_ID_PROD         = credentials('subscription_id_prod')
        
        PLAN_FILE           = "${params.ENVIRONMENT ?: 'dev'}.plan"
    }

    stages {
        stage('Azure Login') {
            steps {
                script {
                    def envName = (params.ENVIRONMENT ?: 'dev').toUpperCase()
                    env.ARM_SUBSCRIPTION_ID = env."SUB_ID_${envName}"
                    
                    echo "=========================================================="
                    echo "INIT: Logging into Azure for ${params.ENVIRONMENT} environment"
                    echo "Subscription ID: ${env.ARM_SUBSCRIPTION_ID}"
                    echo "=========================================================="
                    
                    sh """
                        az login --service-principal \
                            --username "${env.ARM_CLIENT_ID}" \
                            --password "${env.ARM_CLIENT_SECRET}" \
                            --tenant "${env.ARM_TENANT_ID}"

                        echo "Listing available subscriptions:"
                        az account list --output table

                        az account set --subscription "${env.ARM_SUBSCRIPTION_ID}"
                    """
                }
            }
        }

        stage('Terraform Init') {
            steps {
                echo "----------------------------------------------------------"
                echo "TERRAFORM: Initializing for ${params.ENVIRONMENT}"
                sh """
                    
                    
                    terraform -chdir=infrastructure init \
                        -reconfigure \
                        -backend-config="environment/${params.ENVIRONMENT}/${params.ENVIRONMENT}-backend.tf"
                """
            }
        }

        stage('Terraform Validate') {
            steps {
                echo "TERRAFORM: Validating configuration..."
                sh "terraform -chdir=infrastructure validate"
            }
        }

        stage('Terraform Plan') {
            when {
                expression { params.ACTION in ['plan', 'apply', 'destroy'] }
            }
            steps {
                echo "TERRAFORM: Generating execution plan (${params.ACTION})"
                sh """
                    terraform -chdir=infrastructure plan \
                        -var="subscription_id=${env.ARM_SUBSCRIPTION_ID}" \
                        -var-file="environment/${params.ENVIRONMENT}/${params.ENVIRONMENT}.tfvars" \
                        -out="../${env.PLAN_FILE}"
                """
            }
        }

        stage('Approval Required') {
            when {
                expression { (params.ACTION in ['apply', 'destroy']) && params.AUTO_APPROVE == false }
            }
            steps {
                echo "WAIT: Manual approval required to proceed with ${params.ACTION}..."
                timeout(time: 20, unit: 'MINUTES') {
                    input(
                        message: """Approval required for Terraform action.
                        Region: ${params.REGION}
                        Environment: ${params.ENVIRONMENT}
                        Action: ${params.ACTION}
                        Proceed?"""
                    )
                }
            }
        }

        stage('Terraform Apply') {
            when {
                expression { params.ACTION == 'apply' }
            }
            steps {
                echo "TERRAFORM: Applying changes to ${params.ENVIRONMENT}..."
                sh "terraform -chdir=infrastructure apply -auto-approve ../${env.PLAN_FILE}"
                echo "TERRAFORM: Apply completed successfully."
                echo "----------------------------------------------------------"
            }
        }





        stage('Terraform Destroy') {
            when {
                expression { params.ACTION == 'destroy' }
            }
            steps {
                echo "TERRAFORM: Destroying resources in ${params.ENVIRONMENT}..."
                sh """
                    terraform -chdir=infrastructure destroy -auto-approve \
                        -var="subscription_id=${env.ARM_SUBSCRIPTION_ID}" \
                        -var-file="environment/${params.ENVIRONMENT}/${params.ENVIRONMENT}.tfvars"
                """
                echo "TERRAFORM: Successfully destroyed ${params.ENVIRONMENT} resources."
                echo "----------------------------------------------------------"
            }
        }
    }

    post {
        always {
            echo 'Pipeline completed. Cleaning workspace.'
            cleanWs()
        }
        success {
            echo "Terraform completed successfully for ${params.REGION} - ${params.ENVIRONMENT} with action ${params.ACTION}"
        }
        failure {
            echo "Terraform failed for ${params.REGION} - ${params.ENVIRONMENT} with action ${params.ACTION}"
        }
    }
}
